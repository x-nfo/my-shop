{
  "name": "my-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "build": "tsc",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "populate": "ts-node ./src/populate.ts"
  },
  "dependencies": {
    "@vendure/asset-server-plugin": "3.6.0",
    "@vendure/core": "3.6.0",
    "@vendure/dashboard": "3.6.0",
    "@vendure/email-plugin": "3.6.0",
    "@vendure/graphiql-plugin": "3.6.0",
    "dotenv": "17.4.0",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@vendure/cli": "3.6.0",
    "concurrently": "9.2.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  }
}
